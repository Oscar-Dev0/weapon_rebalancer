{
  "name": "Original Body Damage + Real One-Tap",
  "description": "Conserva daño, recoil, cadencia y recarga originales; solo normaliza la ruta META del headshot y casco.",
  "schema_version": 3,
  "base_preset": "rp_balanced",
  "modules": {
    "damage": "original",
    "armour": "original",
    "recoil": "original",
    "accuracy": "original",
    "range": "original",
    "fire_rate": "original",
    "reload": "original",
    "headshot": "onetap"
  },
  "validation": {
    "strict_unknown_fields": true,
    "fail_on_onetap_audit": false,
    "warn_duplicates": true,
    "warn_unregistered_meta": true
  },
  "headshot": {
    "mode": "onetap",
    "multiplier": 1500.0,
    "distance": 300.0,
    "no_falloff": true,
    "sync_weapon_range": true,
    "sync_lock_on_range": false,
    "create_missing_tags": true,
    "bypass_helmets": true,
    "helmet_multiplier": 100.0,
    "force_penetration": true,
    "penetration": 1.0,
    "create_missing_armour_tag": true,
    "create_missing_penetration_tag": true,
    "add_ignore_helmets_flag": true,
    "add_armour_penetrating_flag": true,
    "create_missing_weapon_flags_tag": true,
    "auto_minimum_base_damage": true,
    "target_effective_health": 400.0,
    "safety_margin": 1.25,
    "minimum_base_damage": 0.35,
    "repair_zero_network_modifier": true,
    "network_player_modifier_fallback": 1.0,
    "create_missing_network_player_modifier_tag": true,
    "remove_nonlethal_flags": true,
    "blocking_flags": [
      "NonLethal",
      "NonViolent"
    ]
  },
  "groups": {
    "GROUP_PISTOL": {
      "fields": {},
      "headshot": {
        "mode": "onetap",
        "distance": 130.0
      }
    },
    "GROUP_SMG": {
      "fields": {},
      "headshot": {
        "mode": "onetap",
        "distance": 160.0
      }
    },
    "GROUP_RIFLE": {
      "fields": {},
      "headshot": {
        "mode": "onetap",
        "distance": 320.0
      }
    },
    "GROUP_MG": {
      "fields": {},
      "headshot": {
        "mode": "onetap",
        "distance": 280.0
      }
    },
    "GROUP_SHOTGUN": {
      "fields": {},
      "headshot": {
        "mode": "onetap",
        "distance": 30.0
      }
    },
    "GROUP_SNIPER": {
      "fields": {},
      "headshot": {
        "mode": "onetap",
        "distance": 600.0
      }
    }
  },
  "ignore_weapons": [
    "WEAPON_STUNGUN",
    "WEAPON_FIREEXTINGUISHER"
